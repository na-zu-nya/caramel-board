{
  "name": "caramel-board",
  "version": "1.0.10-beta",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-desktop.mjs",
    "build": "npm run -w @caramelboard/desktop build:app",
    "build:ci": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean --parallel && rm -rf node_modules/.cache node_modules/.vite .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "turbo": "^2.4.2"
  }
}
