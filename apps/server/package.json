{
  "name": "@caramelboard/server",
  "private": true,
  "license": "SEE LICENSE IN ../../LICENSE",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "nodemon dist/entry.node.mjs",
    "start:prod": "node dist/entry.node.mjs",
    "dev": "npm run build && nodemon --watch src --ext ts --exec 'npm run build && node dist/entry.node.mjs'",
    "dev:next": "npm run build && STANDALONE_SQLITE_PATH=${STANDALONE_SQLITE_PATH:-../../exports/imported-reference-check.sqlite} PORT=${PORT:-9000} nodemon --watch src --ext ts --exec 'npm run build && node dist/entry.node.mjs'",
    "build": "esbuild src/entry.node.ts --sourcemap --bundle --platform=node --format=esm --external:sharp --external:dotenv --external:fs-extra --external:form-data --external:dayjs --external:axios --outfile=dist/entry.node.mjs",
    "watch": "npm run build -- --watch",
    "import:standalone": "node scripts/import-standalone-sqlite.mjs",
    "migrate:standalone": "node scripts/migrate-standalone-sqlite.mjs",
    "lint": "biome check src",
    "format": "biome check --write src && biome format --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo node_modules/.cache"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@hono/node-server": "^1.14.3",
    "@hono/zod-validator": "^0.6.0",
    "@types/node": "^22.13.5",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.25.5",
    "hono": "^4.7.10",
    "nodemon": "^3.1.0",
    "rimraf": "^3.0.2",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5",
    "yargs": "^18.0.0",
    "zod": "^3.25.34"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "colorlip": "^1.0.0",
    "dayjs": "^1.10.7",
    "dotenv": "^10.0.0",
    "form-data": "^4.0.2",
    "fs-extra": "^10.1.0",
    "sharp": "^0.34.2"
  }
}
