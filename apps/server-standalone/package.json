{
  "name": "@caramelboard/server-standalone",
  "private": true,
  "version": "1.0.0-beta.2",
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "main": "dist/entry.node.mjs",
  "scripts": {
    "start": "node dist/entry.node.mjs",
    "build": "esbuild src/entry.node.ts --sourcemap --bundle --platform=node --format=esm --outfile=dist/entry.node.mjs",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "check:no-prisma": "node scripts/check-no-prisma.mjs",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@caramelboard/server-core": "^1.0.0-beta.2",
    "@hono/node-server": "^1.14.3",
    "hono": "^4.7.10"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3"
  }
}
